# ============================================
# D3 VPN CLIENT CONFIGURATION
# ============================================

# === СЕРВЕР ===
SERVER_HOST=127.0.0.1
SERVER_PORT=6666

# === КЛИЕНТ ===
CLIENT_NAME=client1

# === МАСКИРОВКА ===
# options: http, https, traffic
MASK_MODE=https

# === ТУННЕЛИРОВАНИЕ ===
# options: icmp, dns, raw
TUNNEL_MODE=icmp

# === DNS ТУННЕЛЬ ===
DNS_DOMAIN=vpn.dns-tunnel.com

# === SOCKS5 ПРОКСИ ===
SOCKS_HOST=127.0.0.1
SOCKS_PORT=1080
SOCKS_ENABLED=true
