# ============================================
# D3 VPN SERVER CONFIGURATION
# ============================================

# === ОСНОВНЫЕ ПАРАМЕТРЫ ===
SERVER_HOST=0.0.0.0
SERVER_PORT=6666
VPN_SUBNET=10.0.0.0/24
ALLOW_INTERNET=true

# === МАСКИРОВКА ===
# options: http, https, traffic
MASK_MODE=https

# === ТУННЕЛИРОВАНИЕ ===
# options: icmp, dns, raw
TUNNEL_MODE=icmp

# === DNS ТУННЕЛЬ ===
DNS_DOMAIN=vpn.dns-tunnel.com

# === СЕРТИФИКАТЫ ===
CA_DIR=certs/ca
AUTO_RENEW_THRESHOLD=7
KEY_ROTATION_INTERVAL=60

# === КАСКАДНОЕ ПОДКЛЮЧЕНИЕ ===
CASCADE_MODE=false
SERVER_LEVEL=0
UPSTREAM_SERVER=192.168.1.100:6666
UPSTREAM_CERT=certs/clients/upstream_cert.pem
UPSTREAM_KEY=certs/clients/upstream_private.pem

# === БАЛАНСИРОВКА ===
BALANCE_ENABLED=false
BALANCE_STRATEGY=adaptive
# Формат: id,host,port,location;id2,host2,port2,location2
BALANCE_SERVERS=server1,192.168.1.101,6666,russia;server2,10.0.0.102,6666,netherlands
BALANCE_API_PORT=8080
SERVER_LOCATION=russia
